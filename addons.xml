<?xml version='1.0' encoding='UTF-8'?>
<addons>
  <addon id="plugin.video.dramacool" name="DramaCool" version="2.0.1" provider-name="groggyegg">
    <requires>
      <import addon="script.module.lxml" optional="true"/>
      <import addon="script.module.resolveurl"/>
      <import addon="script.module.requests"/>
      <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="resources/lib/addon.py">
      <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary lang="en_GB">Video plugin for DramaCool</summary>
      <description lang="en_GB">Watch Asian Drama and Korean Show with English subtitles.</description>
      <platform>all</platform>
      <license>MIT License</license>
      <assets>
        <icon>resources/icon.png</icon>
        <fanart>resources/fanart.jpg</fanart>
      </assets>
    </extension>
  </addon>
  <addon id="plugin.video.duboku" name="Duboku" version="1.0.0" provider-name="groggyegg">
    <requires>
      <import addon="script.module.beautifulsoup4" version="4.6.2"/>
      <import addon="script.module.cloudscraper" version="1.2.40"/>
      <import addon="script.module.routing" version="0.2.3"/>
      <import addon="xbmc.python" version="2.26.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="addon.py">
      <provides>video</provides>
    </extension>
  </addon>
  <addon id="repository.lime" name="Lime Add-ons" version="1.0.2" provider-name="groggyegg">
    <extension point="xbmc.addon.repository" name="Lime Add-ons">
      <dir>
        <info compressed="false">https://raw.githubusercontent.com/groggyegg/lime/master/addons.xml</info>
        <checksum>https://raw.githubusercontent.com/groggyegg/lime/master/addons.xml.md5</checksum>
        <datadir zip="true">https://raw.githubusercontent.com/groggyegg/lime/master</datadir>
      </dir>
      <dir>
        <info compressed="false">https://raw.githubusercontent.com/Gujal00/smrzips/master/addons.xml</info>
        <checksum>https://raw.githubusercontent.com/Gujal00/smrzips/master/addons.xml.md5</checksum>
        <datadir zip="true">https://raw.githubusercontent.com/Gujal00/smrzips/master/zips/</datadir>
      </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary lang="en_GB">Lime Repository</summary>
      <description lang="en_GB">Download and install add-ons from Lime Repository.</description>
      <platform>all</platform>
      <license>MIT License</license>
      <assets>
        <icon>resources/icon.png</icon>
      </assets>
    </extension>
  </addon>
  <addon id="script.module.cloudscraper" name="cloudscraper" version="1.2.40" provider-name="groggyegg">
    <requires>
      <import addon="xbmc.python"/>
      <import addon="script.module.requests" version="2.9.2"/>
      <import addon="script.module.requests-toolbelt" version="0.9.1"/>
    </requires>
    <extension point="xbmc.python.module" library="lib"/>
  </addon>
  <addon id="script.module.requests-toolbelt" name="requests-toolbelt" version="0.9.1" provider-name="groggyegg">
    <requires>
      <import addon="xbmc.python"/>
    </requires>
    <extension point="xbmc.python.module" library="lib"/>
  </addon>
</addons>
